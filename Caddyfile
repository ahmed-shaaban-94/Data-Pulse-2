# Caddy — automatic HTTPS for the public API edge template.
#
# DNS for api.example.test should point at <app-host>. Caddy auto-provisions and
# renews a TLS certificate where the chosen hostname and CA support it, then
# reverse-proxies cleartext to the api container on the internal compose network.
#
# Real deployment hostnames belong in private ops config or the host environment,
# not public git.
# Requires: ports 80 + 443 open and DNS A/AAAA records pointing to <app-host>.

api.example.test {
	encode gzip
	reverse_proxy api:3000

	log {
		output stdout
		format console
	}
}

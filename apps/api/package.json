{
  "name": "@data-pulse-2/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS backend API. Skeleton only — empty AppModule + cross-cutting interceptors / filter / Zod pipe / OpenAPI loader. Domain modules land in later branches.",
  "type": "commonjs",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsc -p tsconfig.build.json --watch",
    "test": "jest --passWithNoTests",
    "lint": "echo \"api: lint runs at the repo root\""
  },
  "dependencies": {
    "@data-pulse-2/shared": "workspace:*",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "cookie-parser": "1.4.7",
    "helmet": "8.1.0",
    "js-yaml": "4.1.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.19",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.5",
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.17.6",
    "@types/supertest": "7.2.0",
    "jest": "29.7.0",
    "supertest": "7.2.2",
    "ts-jest": "29.2.5",
    "typescript": "5.6.3"
  }
}

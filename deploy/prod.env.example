# Data-Pulse-2 deploy env template.
# Copy to deploy/prod.env on <app-host> and fill private references/values.
# Contains NO secret values — only secret-manager references + non-secret config.
# Resolved at runtime by:  op run --env-file=deploy/prod.env -- docker compose ...
#
# DATABASE_URL must point at <managed-db> with SSL required.
# Store the full URL in private ops config or a secret manager, never public git.
# Real deployment values belong in private ops config or the host environment.

DATABASE_URL="<secret-manager-ref>"
REDIS_URL="redis://redis:6379"
LOG_LEVEL="info"

# Clerk backend key — REQUIRED in production (compose declares ${CLERK_SECRET_KEY:?...}).
# Without it `docker compose up` fails at variable substitution before starting.
CLERK_SECRET_KEY="<secret-manager-ref>"
# Optional Clerk hardening (leave blank if unused):
CLERK_AUTHORIZED_PARTIES=""
CLERK_JWT_AUDIENCE=""

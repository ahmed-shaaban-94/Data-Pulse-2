# Data-Pulse-2 P-0 preprod — REFERENCE-ONLY env template.
# Copy to deploy/prod.env ON THE DROPLET and fill the op:// references.
# Contains NO secret values — only 1Password references + non-secret config.
# Resolved at runtime by:  op run --env-file=deploy/prod.env -- docker compose ...
#
# DATABASE_URL must point at the MANAGED ezaby cluster's PRIVATE host with SSL,
# e.g. postgresql://<user>:<pass>@private-<...>.db.ondigitalocean.com:25060/defaultdb?sslmode=require
# Store the full URL as a 1Password field and reference it here — never inline the value.

DATABASE_URL="op://Tower-OS/ezaby-preprod/database_url"
REDIS_URL="redis://redis:6379"
LOG_LEVEL="info"

# Clerk backend key — REQUIRED in production (compose declares ${CLERK_SECRET_KEY:?...}).
# Without it `docker compose up` fails at variable substitution before starting.
CLERK_SECRET_KEY="op://Tower-OS/Clerk/secret_key"
# Optional Clerk hardening (leave blank if unused):
CLERK_AUTHORIZED_PARTIES=""
CLERK_JWT_AUDIENCE=""

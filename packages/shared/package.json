{
  "name": "@data-pulse-2/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utilities: Zod base schemas, error envelope, pino logger, OTel setup. Backend-only; no DOM types.",
  "type": "commonjs",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./zod/base": "./src/zod/base.ts",
    "./errors/envelope": "./src/errors/envelope.ts",
    "./logger/pino": "./src/logger/pino.ts",
    "./observability/otel": "./src/observability/otel.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "lint": "echo \"shared: lint runs at the repo root\""
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.216.0",
    "@opentelemetry/instrumentation-http": "0.216.0",
    "@opentelemetry/instrumentation-pg": "0.68.0",
    "@opentelemetry/instrumentation-redis": "0.64.0",
    "@opentelemetry/sdk-node": "0.216.0",
    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.17.6",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.6.3"
  }
}

{
  "name": "@data-pulse-2/auth",
  "version": "0.0.0",
  "private": true,
  "description": "Authentication primitives shared by api and worker: argon2id password helper, SHA-256 token-hash helper, session/token shape types.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./passwords": {
      "types": "./dist/passwords.d.ts",
      "default": "./dist/passwords.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "lint": "echo \"auth: lint runs at the repo root\""
  },
  "dependencies": {
    "@clerk/backend": "3.4.5",
    "argon2": "0.44.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.17.6",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.6.3"
  }
}
